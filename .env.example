# Root-level placeholder. Real values live in each app's own .env.local,
# which is gitignored. This file documents what exists — it holds no secrets.

# --- Supabase ---
# Local dev: values `supabase start` prints. Deployed (Vercel, etc.): your
# HOSTED Supabase project's URL/anon key (Dashboard → Project Settings →
# API) — never a localhost URL, which a deployed server can't reach.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- MEF Conversation Coach (Milestone 7), consumer-web-app only ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# --- Wearables + Proactive AI Coach, consumer-web-app only ---
CRON_SECRET=
OURA_CLIENT_ID=
APPLE_HEALTH_CLIENT_ID=
GOOGLE_FIT_CLIENT_ID=

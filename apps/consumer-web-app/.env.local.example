# Copy to .env.local and fill in with the values `supabase start` prints.
#
# IMPORTANT — these two are also required in any deployed environment
# (Vercel Project Settings → Environment Variables), and there they must be
# your HOSTED Supabase project's URL/anon key (Supabase Dashboard → Project
# Settings → API), never http://localhost:54321. A deployed server can't
# reach your machine's local Supabase container — pointing production at it
# fails every auth call with an opaque "fetch failed" (see lib/supabase/env.ts,
# which now throws a clearer error at least when the var is missing entirely).
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, NEVER exposed with NEXT_PUBLIC_, NEVER used
# in a client component. Used by seed/admin scripts, and by the one
# background job in this app — app/api/cron/wearable-daily/route.ts.
SUPABASE_SERVICE_ROLE_KEY=
# Used to build email confirmation / password-reset redirect links
# (app/actions/auth.ts). In Vercel this must be your real deployed URL
# (e.g. https://your-app.vercel.app), not localhost — and that same URL
# must also be added to Supabase Dashboard → Authentication → URL
# Configuration → Redirect URLs, or the auth email links will fail even
# with everything else configured correctly.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Wearables + Proactive AI Coach — verifies the daily cron request
# actually came from Vercel Cron (it sends `Authorization: Bearer
# $CRON_SECRET`), not some other caller of this route.
CRON_SECRET=

# Wearable provider credentials — server-only. Every provider is an
# UnconfiguredProvider stub (lib/wearables/providers/registry.ts) until
# its client id is set here; leaving these blank is the expected state
# for this milestone.
OURA_CLIENT_ID=
APPLE_HEALTH_CLIENT_ID=
GOOGLE_FIT_CLIENT_ID=

# MEF Conversation Coach (Milestone 7) — server-only, never exposed with
# NEXT_PUBLIC_. Both must be set for the Conversation Coach to call a real
# model; without them it automatically falls back to the deterministic
# fallback experience (lib/conversation-coach/fallback.ts) rather than
# failing. See lib/ai/providers/anthropic.ts.
ANTHROPIC_API_KEY=
# The exact model id available on your Anthropic account, e.g.
# claude-sonnet-4-5-20250929 — intentionally left blank rather than
# defaulted, since a wrong hardcoded model id would fail silently at
# request time.
ANTHROPIC_MODEL=

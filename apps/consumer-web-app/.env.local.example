# Copy to .env.local and fill in with the values `supabase start` prints.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, NEVER exposed with NEXT_PUBLIC_, NEVER used
# in a client component. Used only by seed/admin scripts run outside the
# request path, not by the app itself in Sprint 1.
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
